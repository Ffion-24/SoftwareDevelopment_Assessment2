import random

#Random Loction Treasure
treasure_row = random.randint(0, 4)
treasure_column = random.randint(0, 4)
while treasure_row == 4 and treasure_column == 0:
    treasure_row = random.randint(0, 4)
    treasure_column = random.randint(0, 4)

#Random Location Trap

trap_row = random.randint(0, 4)  # This generates a random location for the trap...
trap_column = random.randint(0, 4)
while (trap_row == 4 and trap_column == 0) or (trap_row == treasure_row and trap_column == treasure_column): # ...but this stops the player failing instantly.
    trap_row = random.randint(0, 4)
    trap_column = random.randint(0, 4)

#Greeting

def greetUser():
    welcome= "Welcome to the Python Treasure Hunt" # telling the code that any time greetUser is mentioned the vairible welcome is actioned
    return welcome

print(greetUser())

#Player Grid
player_row = 4
player_column = 0

def display_grid():
    rows= 5
    coulums= 5
    for i in range(rows):
        for j in range(coulums):
            if i == player_row and j== player_column:
                print("P", end=" ") #This is to print the P in the last row and first column as the starting point of the game.
            else:
                print(".", end=" ") # this is to print the dots in a line and not in a new line
        print() # this is to move to the next line after printing the dots in a line

display_grid()

#Player Health
player_hp = 3
print("Player Health: ", player_hp)
while player_hp > 0 and  (player_row, player_column) == (trap_row, trap_column):
    player_hp -= 1
    print("Player Health: ", player_hp)

#Player Movement
print("You are at the starting point. Move up (w), down(s), left(a) or right(d) to find the hidden treasure.")
while player_hp > 0 and (player_row, player_column) != (treasure_row, treasure_column):
    player_movement = input("Enter your move: ")
    if player_movement == "w":
        if player_row == 0:
            print("Error: You can't move up.")
        else:
            player_row += -1
            display_grid()
            print("Player Health: ", player_hp)
    elif player_movement == "s":
        if player_row == 4:
            print("Error: You can't move down.")
        else:
            player_row += 1
            display_grid()
            print("Player Health: ", player_hp)
    elif player_movement == "a":
        if player_column == 0:
            print("Error: You can't move left.")
        else:
            player_column += -1
            display_grid()
            print("Player Health: ", player_hp)
    elif player_movement == "d":
        if player_column == 4:
            print("Error: You can't move right.")
        else:
            player_column += 1
            display_grid()
            print("Player Health: ", player_hp)
        
    else:
        print("Error: Invalid move. Please enter w, s, a, or d.")
if (player_row, player_column) == (treasure_row, treasure_column):
    print("Congratulations! You found the treasure!")
elif player_hp == 0:
    print("Game Over! You have lost all of your health.")
